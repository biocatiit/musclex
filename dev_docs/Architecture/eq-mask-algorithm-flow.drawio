                <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" parent="1" source="setimage" target="rotate" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
