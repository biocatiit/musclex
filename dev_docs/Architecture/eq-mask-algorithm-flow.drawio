                <mxCell id="e14" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;" parent="1" source="smoothDecision" target="gapPath" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
